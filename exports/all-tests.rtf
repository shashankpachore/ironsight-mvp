import \{ beforeEach, describe, expect, it \} from "vitest";\par
import \{ Outcome, UserRole \} from "@prisma/client";\par
import \{ GET as getInsights \} from "../app/api/manager/insights/route";\par
import \{ prisma \} from "../lib/prisma";\par
import \{ approveAccount, assignAccount, createAccount, createDeal, json, makeRequest, resetDbAndSeedUsers, uniqueName \} from "./helpers";\par
\par
function daysFromNow(deltaDays: number): Date \{\par
  return new Date(Date.now() + deltaDays * 86_400_000);\par
\}\par
\par
describe("manager insights api", () => \{\par
  let users: Awaited<ReturnType<typeof resetDbAndSeedUsers>>;\par
  let repAccountId: string;\par
  let rep2AccountId: string;\par
\par
  beforeEach(async () => \{\par
    users = await resetDbAndSeedUsers();\par
\par
    const repAcc = await json<\{ id: string \}>(\par
      await createAccount(\{ byUserId: users.admin.id, name: uniqueName("Insights-Rep") \}),\par
    );\par
    repAccountId = repAcc.id;\par
    await approveAccount(\{ byUserId: users.admin.id, accountId: repAcc.id \});\par
    await assignAccount(\{ byUserId: users.admin.id, accountId: repAcc.id, assigneeId: users.rep.id \});\par
\par
    const rep2Acc = await json<\{ id: string \}>(\par
      await createAccount(\{ byUserId: users.admin.id, name: uniqueName("Insights-Rep2") \}),\par
    );\par
    rep2AccountId = rep2Acc.id;\par
    await approveAccount(\{ byUserId: users.admin.id, accountId: rep2Acc.id \});\par
    await assignAccount(\{ byUserId: users.admin.id, accountId: rep2Acc.id, assigneeId: users.rep2.id \});\par
  \});\par
\par
  it("returns 401 without session", async () => \{\par
    const res = await getInsights(makeRequest("http://localhost/api/manager/insights"));\par
    expect(res.status).toBe(401);\par
  \});\par
\par
  it("returns 403 for REP", async () => \{\par
    const res = await getInsights(\par
      makeRequest("http://localhost/api/manager/insights", \{ userId: users.rep.id \}),\par
    );\par
    expect(res.status).toBe(403);\par
  \});\par
\par
  it("manager scope: only sees their reps, returns atRiskDeals + interventions", async () => \{\par
    const committed = await json<\{ id: string \}>(\par
      await createDeal(\{\par
        byUserId: users.rep.id,\par
        accountId: repAccountId,\par
        name: uniqueName("Committed"),\par
        value: 100_000,\par
      \}),\par
    );\par
\par
    // Make the deal CRITICAL by inactivity\par
    await prisma.deal.update(\{\par
      where: \{ id: committed.id \},\par
      data: \{ lastActivityAt: daysFromNow(-12), nextStepDate: daysFromNow(2), nextStepType: "FOLLOW_UP" \},\par
    \});\par
\par
    // Force COMMITTED stage using existing outcomes (direct inserts are used elsewhere in tests)\par
    const old = daysFromNow(-12);\par
    await prisma.interactionLog.createMany(\{\par
      data: [\par
        \{ dealId: committed.id, interactionType: "CALL", outcome: Outcome.MET_DECISION_MAKER, stakeholderType: "DECISION_MAKER", notes: "dm", createdAt: new Date(old.getTime() + 1_000) \},\par
        \{ dealId: committed.id, interactionType: "CALL", outcome: Outcome.BUDGET_DISCUSSED, stakeholderType: "DECISION_MAKER", notes: "budget", createdAt: new Date(old.getTime() + 2_000) \},\par
        \{ dealId: committed.id, interactionType: "CALL", outcome: Outcome.PROPOSAL_SHARED, stakeholderType: "DECISION_MAKER", notes: "proposal", createdAt: new Date(old.getTime() + 3_000) \},\par
        \{ dealId: committed.id, interactionType: "CALL", outcome: Outcome.DEAL_CONFIRMED, stakeholderType: "DECISION_MAKER", notes: "confirm", createdAt: new Date(old.getTime() + 4_000) \},\par
      ],\par
    \});\par
\par
    const otherTeamDeal = await json<\{ id: string \}>(\par
      await createDeal(\{\par
        byUserId: users.rep2.id,\par
        accountId: rep2AccountId,\par
        name: uniqueName("OtherTeam"),\par
        value: 100_000,\par
      \}),\par
    );\par
    await prisma.deal.update(\{\par
      where: \{ id: otherTeamDeal.id \},\par
      data: \{ lastActivityAt: daysFromNow(-15), nextStepDate: daysFromNow(1), nextStepType: "FOLLOW_UP" \},\par
    \});\par
    await prisma.interactionLog.create(\{\par
      data: \{\par
        dealId: otherTeamDeal.id,\par
        interactionType: "CALL",\par
        outcome: Outcome.PROPOSAL_SHARED,\par
        stakeholderType: "DECISION_MAKER",\par
        notes: "proposal",\par
        createdAt: daysFromNow(-15),\par
      \},\par
    \});\par
\par
    const res = await getInsights(\par
      makeRequest("http://localhost/api/manager/insights", \{ userId: users.manager.id \}),\par
    );\par
    expect(res.status).toBe(200);\par
    const body = await json<\{\par
      atRiskDeals: Array<\{ dealId: string; stage: string; ownerName: string \}>;\par
      repHealth: Array<\{ repId: string; color: string \}>;\par
      interventions: Array<\{ dealId: string; suggestedAction: string \}>;\par
    \}>(res);\par
\par
    // Scope: should include the committed rep deal, not the other manager's rep deal\par
    expect(body.atRiskDeals.map((d) => d.dealId)).toContain(committed.id);\par
    expect(body.atRiskDeals.map((d) => d.dealId)).not.toContain(otherTeamDeal.id);\par
\par
    const committedRow = body.atRiskDeals.find((d) => d.dealId === committed.id);\par
    expect(committedRow?.stage).toBe("COMMITTED");\par
    expect(committedRow?.ownerName).toBe("Rep");\par
\par
    const intervention = body.interventions.find((i) => i.dealId === committed.id);\par
    expect(intervention?.suggestedAction).toBe("Manager should step in — high risk close");\par
  \});\par
\par
  it("repHealth RED when criticalDeals > 5; YELLOW on low activity rule", async () => \{\par
    // Create 6 CRITICAL deals for users.rep\par
    for (let i = 0; i < 6; i++) \{\par
      const d = await json<\{ id: string \}>(\par
        await createDeal(\{\par
          byUserId: users.rep.id,\par
          accountId: repAccountId,\par
          name: uniqueName(`Critical-$\{i\}`),\par
          value: 10_000,\par
        \}),\par
      );\par
      await prisma.deal.update(\{\par
        where: \{ id: d.id \},\par
        data: \{ lastActivityAt: daysFromNow(-11), nextStepDate: daysFromNow(2), nextStepType: "FOLLOW_UP" \},\par
      \});\par
    \}\par
\par
    const res = await getInsights(\par
      makeRequest("http://localhost/api/manager/insights", \{ userId: users.manager.id \}),\par
    );\par
    expect(res.status).toBe(200);\par
    const body = await json<\{\par
      repHealth: Array<\{ repId: string; color: "RED" | "YELLOW" | "GREEN"; criticalDeals: number \}>;\par
    \}>(res);\par
\par
    const repRow = body.repHealth.find((r) => r.repId === users.rep.id);\par
    expect(repRow?.criticalDeals).toBeGreaterThanOrEqual(6);\par
    expect(repRow?.color).toBe("RED");\par
  \});\par
\});\par
\par


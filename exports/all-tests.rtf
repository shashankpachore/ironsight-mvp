\});\par
\par
describe("getSuggestedNextStep", () => \{\par
  it("Demo Done → SEND_PRICING", () => \{\par
    expect(getSuggestedNextStep(Outcome.DEMO_DONE).type).toBe("SEND_PRICING");\par
  \});\par

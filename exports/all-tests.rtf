  it("csv has required headers", async () => \{\par
    const res = await getExportRoute(makeRequest("http://localhost/api/export", \{ userId: users.admin.id \}));\par
    const text = await res.text();\par
    const \{ header \} = parseCsv(text);\par
    expect(header).toBe("Account Name,Assigned Rep,Deal Value,Stage,Last Activity Date,Missing Signals");\par
  \});\par
\par
  it("csv row count matches deals count", async () => \{\par

import \{ describe, expect, it \} from "vitest";\par
import \{ getSuggestedNextStep \} from "../lib/next-step";\par
import \{ classifyDeal \} from "../lib/today-logic";\par
\par
const today = new Date("2026-01-10T00:00:00.000Z");\par
\par
function daysFrom(base: Date, delta: number): Date \{\par
  return new Date(base.getTime() + delta * 86_400_000);\par
\}\par
\par
describe("logic core - next step suggestion", () => \{\par
  it("Demo Done -> SEND_PRICING", () => \{\par
    expect(getSuggestedNextStep("DEMO_DONE").type).toBe("SEND_PRICING");\par
  \});\par
\par
  it("Pricing Requested -> SEND_PRICING", () => \{\par
    expect(getSuggestedNextStep("PRICING_REQUESTED").type).toBe("SEND_PRICING");\par
  \});\par
\par
  it("Budget Discussed -> SEND_PROPOSAL", () => \{\par
    expect(getSuggestedNextStep("BUDGET_DISCUSSED").type).toBe("SEND_PROPOSAL");\par
  \});\par
\par
  it("Proposal Shared -> FOLLOW_UP", () => \{\par
    expect(getSuggestedNextStep("PROPOSAL_SHARED").type).toBe("FOLLOW_UP");\par
  \});\par
\par
  it("Negotiation Started -> FOLLOW_UP", () => \{\par
    expect(getSuggestedNextStep("NEGOTIATION_STARTED").type).toBe("FOLLOW_UP");\par
  \});\par
\par
  it("No Response -> FOLLOW_UP", () => \{\par
    expect(getSuggestedNextStep("NO_RESPONSE").type).toBe("FOLLOW_UP");\par
  \});\par
\par
  it("Not Interested -> CLOSE_DEAL", () => \{\par
    expect(getSuggestedNextStep("Not Interested").type).toBe("CLOSE_DEAL");\par
  \});\par
\});\par
\par
describe("logic core - today classification", () => \{\par
  it("CRITICAL when next step is 5 days overdue", () => \{\par
    expect(\par
      classifyDeal(\{\par
        nextStepDate: daysFrom(today, -5),\par
        lastActivityAt: daysFrom(today, -1),\par
        today,\par
      \}),\par
    ).toBe("CRITICAL");\par
  \});\par
\par
  it("CRITICAL when last activity is 12 days old", () => \{\par
    expect(\par
      classifyDeal(\{\par
        nextStepDate: daysFrom(today, 5),\par
        lastActivityAt: daysFrom(today, -12),\par
        today,\par
      \}),\par
    ).toBe("CRITICAL");\par
  \});\par
\par
  it("ATTENTION when last activity is 8 days old", () => \{\par
    expect(\par
      classifyDeal(\{\par
        nextStepDate: daysFrom(today, 5),\par
        lastActivityAt: daysFrom(today, -8),\par
        today,\par
      \}),\par
    ).toBe("ATTENTION");\par
  \});\par
\par
  it("UPCOMING when next step is today", () => \{\par
    expect(\par
      classifyDeal(\{\par
        nextStepDate: today,\par
        lastActivityAt: daysFrom(today, -1),\par
        today,\par
      \}),\par
    ).toBe("UPCOMING");\par
  \});\par
\par
  it("UPCOMING when next step is tomorrow", () => \{\par
    expect(\par
      classifyDeal(\{\par
        nextStepDate: daysFrom(today, 1),\par
        lastActivityAt: daysFrom(today, -2),\par
        today,\par
      \}),\par
    ).toBe("UPCOMING");\par
  \});\par
\par
  it("IGNORE for recent activity and future next step", () => \{\par
    expect(\par
      classifyDeal(\{\par
        nextStepDate: daysFrom(today, 7),\par
        lastActivityAt: daysFrom(today, -3),\par
        today,\par
      \}),\par
    ).toBe("IGNORE");\par
  \});\par
\});\par


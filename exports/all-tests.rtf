import \{ createDeal, json, makeRequest, resetDbAndSeedUsers, uniqueName \} from "./helpers";\par
\par
async function seedApprovedAccount(params: \{ adminId: string; assigneeId: string \}) \{\par
  return prisma.account.create(\{\par
    data: \{\par
      name: uniqueName("NextAcct"),\par
      normalized: uniqueName("norm").toLowerCase(),\par
      createdById: params.adminId,\par
      assignedToId: params.assigneeId,\par
      status: AccountStatus.APPROVED,\par
    \},\par
  \});\par
\}\par
\par
function baseLogBody(dealId: string, overrides: Record<string, unknown> = \{\}) \{\par
  return \{\par
    dealId,\par
    interactionType: "CALL",\par
    outcome: "FOLLOW_UP_DONE",\par
    stakeholderType: "UNKNOWN",\par
    risks: ["NO_ACCESS_TO_DM"],\par
    notes: "note",\par
    nextStepType: "AWAIT_RESPONSE",\par
    nextStepDate: new Date("2026-04-01T00:00:00.000Z").toISOString(),\par
    ...overrides,\par
  \};\par
\}\par
\par
describe("mandatory next step — POST /api/logs", () => \{\par
  let users: Awaited<ReturnType<typeof resetDbAndSeedUsers>>;\par
  let dealId: string;\par
\par
  beforeEach(async () => \{\par
    users = await resetDbAndSeedUsers();\par
    const account = await seedApprovedAccount(\{ adminId: users.admin.id, assigneeId: users.rep.id \});\par
    const dealRes = await createDeal(\{\par
      byUserId: users.rep.id,\par
      name: uniqueName("NextStepDeal"),\par
      value: 50,\par
      accountId: account.id,\par
    \});\par
    dealId = (await json<\{ id: string \}>(dealRes)).id;\par
    await prisma.deal.update(\{\par
      where: \{ id: dealId \},\par
      data: \{ nextStepType: null, nextStepDate: null, nextStepSource: null \},\par
    \});\par
  \});\par
\par
  it("fails 400 when nextStepType is missing", async () => \{\par
    const body = baseLogBody(dealId);\par
    delete (body as Record<string, unknown>).nextStepType;\par
    const res = await postLogRoute(\par
      makeRequest("http://localhost/api/logs", \{ method: "POST", userId: users.rep.id, body \}),\par
    );\par
    expect(res.status).toBe(400);\par
  \});\par
\par
  it("fails 400 when nextStepDate is missing", async () => \{\par
    const body = baseLogBody(dealId);\par
    delete (body as Record<string, unknown>).nextStepDate;\par
    const res = await postLogRoute(\par
      makeRequest("http://localhost/api/logs", \{ method: "POST", userId: users.rep.id, body \}),\par
    );\par
    expect(res.status).toBe(400);\par
  \});\par
\par
  it("succeeds 201 when both next step fields are provided", async () => \{\par
    const res = await postLogRoute(\par
      makeRequest("http://localhost/api/logs", \{\par
        method: "POST",\par
        userId: users.rep.id,\par
        body: baseLogBody(dealId, \{\par
          nextStepType: "FOLLOW_UP",\par
          nextStepDate: new Date("2026-05-01T00:00:00.000Z").toISOString(),\par
        \}),\par
      \}),\par
    );\par
    expect(res.status).toBe(201);\par
  \});\par
\par
  it("updates deal nextStepType and nextStepDate after log creation", async () => \{\par
    const nextDate = new Date("2026-05-15T00:00:00.000Z").toISOString();\par
    await postLogRoute(\par
      makeRequest("http://localhost/api/logs", \{\par
        method: "POST",\par
        userId: users.rep.id,\par
        body: baseLogBody(dealId, \{ nextStepType: "SEND_PRICING", nextStepDate: nextDate \}),\par
      \}),\par
    );\par
    const deal = await prisma.deal.findUnique(\{ where: \{ id: dealId \} \});\par
    expect(deal?.nextStepType).toBe("SEND_PRICING");\par
    expect(deal?.nextStepDate?.toISOString()).toBe(nextDate);\par
  \});\par
\par
  it("deal without prior next step still accepts a log", async () => \{\par
    const res = await postLogRoute(\par
      makeRequest("http://localhost/api/logs", \{\par
        method: "POST",\par
        userId: users.rep.id,\par
        body: baseLogBody(dealId, \{\par
          nextStepType: "OTHER",\par
          nextStepDate: new Date("2026-06-01T00:00:00.000Z").toISOString(),\par
        \}),\par
      \}),\par
    );\par
    expect(res.status).toBe(201);\par
    const deal = await prisma.deal.findUnique(\{ where: \{ id: dealId \} \});\par
    expect(deal?.nextStepType).toBe("OTHER");\par
  \});\par
\par
  it("rep cannot log on another rep’s assigned deal (403)", async () => \{\par
    const account = await seedApprovedAccount(\{ adminId: users.admin.id, assigneeId: users.rep2.id \});\par
    const dealRes = await createDeal(\{\par
      byUserId: users.rep2.id,\par
      name: uniqueName("Rep2Deal"),\par
      value: 75,\par
      accountId: account.id,\par
    \});\par
    const otherDealId = (await json<\{ id: string \}>(dealRes)).id;\par
\par
    const res = await postLogRoute(\par
      makeRequest("http://localhost/api/logs", \{\par
        method: "POST",\par
        userId: users.rep.id,\par
        body: baseLogBody(otherDealId),\par

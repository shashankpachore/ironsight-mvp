  it("approve endpoint rejects invalid user header with 401", async () => \{\par
    const created = await json<\{ id: string \}>(await createAccount(\{ byUserId: users.rep.id, name: uniqueName("HeaderFallback") \}));\par
    const res = await approveAccountRoute(\par
      makeRequest("http://localhost/api/accounts/approve", \{ method: "POST", userId: "fake-user", body: \{\} \}),\par
      \{ params: Promise.resolve(\{ id: created.id \}) \},\par
    );\par

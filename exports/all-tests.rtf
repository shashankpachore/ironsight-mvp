import \{ describe, expect, it, vi, beforeEach \} from "vitest";\par
import \{ Outcome, InteractionType, StakeholderType, RiskCategory \} from "@prisma/client";\par
import \{ getDealStage, getMissingSignals \} from "../lib/deals";\par
import \{\par
  validateDealInput,\par
  validateLogInput,\par
  validateOutcomeGuardrails,\par
\} from "../lib/validation";\par
\par
const \{ prismaMock \} = vi.hoisted(() => (\{\par
  prismaMock: \{\par
    interactionLog: \{\par
      findMany: vi.fn(),\par
    \},\par
    deal: \{\par
      findUnique: vi.fn(),\par
    \},\par
  \},\par
\}));\par
\par
vi.mock("../lib/prisma", () => (\{\par
  prisma: prismaMock,\par
\}));\par
\par
type Scenario = \{\par
  key: string;\par
  outcomes: Outcome[];\par
  lastActivityAtDaysAgo?: number;\par
  logsDaysAgo?: number;\par
  expectedStage: "ACCESS" | "QUALIFIED" | "EVALUATION" | "COMMITTED" | "CLOSED" | "LOST";\par
  expectedMissingSignals?: string[];\par
\};\par
\par
const scenarios: Scenario[] = [\par
  \{\par
    key: "clean-ideal-deal",\par
    outcomes: [\par
      Outcome.MET_DECISION_MAKER,\par
      Outcome.BUDGET_DISCUSSED,\par
      Outcome.PROPOSAL_SHARED,\par
      Outcome.DEAL_CONFIRMED,\par
    ],\par
    expectedStage: "COMMITTED",\par
    expectedMissingSignals: [],\par
  \},\par
  \{\par
    key: "no-decision-maker",\par
    outcomes: [Outcome.BUDGET_DISCUSSED, Outcome.PROPOSAL_SHARED],\par
    expectedStage: "EVALUATION",\par
    expectedMissingSignals: ["Missing Decision Maker"],\par
  \},\par
  \{\par
    key: "no-budget",\par
    outcomes: [Outcome.MET_DECISION_MAKER, Outcome.PROPOSAL_SHARED],\par
    expectedStage: "EVALUATION",\par
    expectedMissingSignals: ["Missing Budget Discussion"],\par
  \},\par
  \{\par
    key: "only-influencer-interactions",\par
    outcomes: [Outcome.MET_INFLUENCER, Outcome.FOLLOW_UP_DONE],\par
    expectedStage: "ACCESS",\par
    expectedMissingSignals: [\par
      "Missing Decision Maker",\par
      "Missing Budget Discussion",\par
      "Missing Proposal",\par
    ],\par
  \},\par
  \{\par
    key: "only-no-movement-logs",\par
    outcomes: [Outcome.NO_RESPONSE, Outcome.NO_RESPONSE, Outcome.NO_RESPONSE],\par
    expectedStage: "ACCESS",\par
    expectedMissingSignals: [\par
      "Missing Decision Maker",\par
      "Missing Budget Discussion",\par
      "Missing Proposal",\par
    ],\par
  \},\par
  \{\par
    key: "fake-high-progress-incorrect-signals",\par
    outcomes: [Outcome.PROPOSAL_SHARED],\par
    expectedStage: "EVALUATION",\par
    expectedMissingSignals: ["Missing Decision Maker", "Missing Budget Discussion"],\par
  \},\par
  \{\par
    key: "stale-deal-no-activity",\par
    outcomes: [Outcome.MET_INFLUENCER],\par
    lastActivityAtDaysAgo: 8,\par
    logsDaysAgo: 8,\par
    expectedStage: "ACCESS",\par
    expectedMissingSignals: [\par
      "Missing Decision Maker",\par
      "Missing Budget Discussion",\par
      "Missing Proposal",\par
      "No Recent Activity (7 days)",\par
    ],\par
  \},\par
  \{\par
    key: "over-logged-deal",\par
    outcomes: [\par
      Outcome.NO_RESPONSE,\par
      Outcome.FOLLOW_UP_DONE,\par
      Outcome.MET_INFLUENCER,\par
      Outcome.NO_RESPONSE,\par
      Outcome.INTERNAL_DISCUSSION,\par
      Outcome.FOLLOW_UP_DONE,\par
      Outcome.NO_RESPONSE,\par
      Outcome.MET_INFLUENCER,\par
      Outcome.NO_RESPONSE,\par
      Outcome.DECISION_DELAYED,\par
      Outcome.NO_RESPONSE,\par
    ],\par
    expectedStage: "ACCESS",\par
    expectedMissingSignals: [\par
      "Missing Decision Maker",\par
      "Missing Budget Discussion",\par
      "Missing Proposal",\par
    ],\par
  \},\par
  \{\par
    key: "conflicting-signals",\par
    outcomes: [\par
      Outcome.DEAL_DROPPED,\par
      Outcome.PROPOSAL_SHARED,\par
      Outcome.NEGOTIATION_STARTED,\par
      Outcome.BUDGET_NOT_AVAILABLE,\par

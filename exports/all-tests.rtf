  await assignAccount(\{\par
    byUserId: params.adminId,\par
    accountId: account.id,\par
    assigneeId: params.ownerId,\par
  \});\par
  const dealRes = await createDeal(\{\par
    byUserId: params.ownerId,\par
    accountId: account.id,\par
    name: uniqueName(`Deal-$\{params.label\}`),\par

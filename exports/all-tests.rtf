\par
describe("users e2e", () => \{\par
  let users: Awaited<ReturnType<typeof resetDbAndSeedUsers>>;\par
\par
  beforeEach(async () => \{\par
    users = await resetDbAndSeedUsers();\par
  \});\par
\par
  it("admin can create REP", async () => \{\par
    const res = await usersPOST(\par
      makeRequest("http://localhost/api/users", \{\par
        method: "POST",\par
        userId: users.admin.id,\par
        body: \{\par
          name: "New Rep",\par
          email: "newrep@ironsight.local",\par
          password: "pass1234",\par
          role: UserRole.REP,\par
          managerId: users.manager.id,\par
        \},\par
      \}),\par
    );\par
    expect(res.status).toBe(201);\par
  \});\par
\par
  it("admin can create MANAGER", async () => \{\par
    const res = await usersPOST(\par
      makeRequest("http://localhost/api/users", \{\par
        method: "POST",\par
        userId: users.admin.id,\par
        body: \{\par
          name: "New Manager",\par
          email: "newmgr@ironsight.local",\par
          password: "pass1234",\par
          role: UserRole.MANAGER,\par
        \},\par
      \}),\par
    );\par
    expect(res.status).toBe(201);\par
  \});\par
\par
  it("admin can update user", async () => \{\par
    const createRes = await usersPOST(\par
      makeRequest("http://localhost/api/users", \{\par
        method: "POST",\par
        userId: users.admin.id,\par
        body: \{\par
          name: "To Update",\par
          email: "upd@ironsight.local",\par
          password: "pass",\par
          role: UserRole.REP,\par
          managerId: users.manager.id,\par
        \},\par
      \}),\par
    );\par
    const created = await json<\{ id: string \}>(createRes);\par
    const patchRes = await userPATCH(\par
      makeRequest(`http://localhost/api/users/$\{created.id\}`, \{\par
        method: "PATCH",\par
        userId: users.admin.id,\par
        body: \{ name: "Updated Name" \},\par
      \}),\par
      \{ params: Promise.resolve(\{ id: created.id \}) \},\par
    );\par
    expect(patchRes.status).toBe(200);\par
  \});\par
\par
  it("admin can delete user without dependencies", async () => \{\par
    const createRes = await usersPOST(\par
      makeRequest("http://localhost/api/users", \{\par
        method: "POST",\par
        userId: users.admin.id,\par
        body: \{ name: "Delete Me", email: "deleteme@ironsight.local", password: "pass", role: UserRole.MANAGER \},\par
      \}),\par
    );\par
    const created = await json<\{ id: string \}>(createRes);\par
    const delRes = await userDELETE(\par
      makeRequest(`http://localhost/api/users/$\{created.id\}`, \{\par
        method: "DELETE",\par
        userId: users.admin.id,\par
      \}),\par
      \{ params: Promise.resolve(\{ id: created.id \}) \},\par
    );\par
    expect(delRes.status).toBe(200);\par
  \});\par
\par
  it("admin cannot delete self", async () => \{\par
    const res = await userDELETE(\par
      makeRequest(`http://localhost/api/users/$\{users.admin.id\}`, \{\par
        method: "DELETE",\par
        userId: users.admin.id,\par
      \}),\par
      \{ params: Promise.resolve(\{ id: users.admin.id \}) \},\par
    );\par
    expect(res.status).toBe(400);\par
  \});\par
\par
  it("admin cannot delete another admin", async () => \{\par
    const otherAdmin = await prisma.user.create(\{\par
      data: \{ name: "Admin2", email: "admin2@ironsight.local", password: "pass", role: UserRole.ADMIN \},\par
    \});\par
    const res = await userDELETE(\par
      makeRequest(`http://localhost/api/users/$\{otherAdmin.id\}`, \{\par
        method: "DELETE",\par
        userId: users.admin.id,\par
      \}),\par
      \{ params: Promise.resolve(\{ id: otherAdmin.id \}) \},\par
    );\par
    expect(res.status).toBe(400);\par
  \});\par
\par
  it("cannot delete user with dependencies", async () => \{\par
    const account = await prisma.account.create(\{\par
      data: \{\par
        name: "Dep Co",\par
        normalized: "dep co",\par
        status: "APPROVED",\par
        createdById: users.rep.id,\par
        assignedToId: users.rep.id,\par
      \},\par
    \});\par
    await prisma.deal.create(\{\par
      data: \{\par
        name: "CRM",\par
        companyName: account.name,\par
        value: 10,\par
        accountId: account.id,\par
        ownerId: users.rep.id,\par
      \},\par
    \});\par
    const res = await userDELETE(\par
      makeRequest(`http://localhost/api/users/$\{users.rep.id\}`, \{ method: "DELETE", userId: users.admin.id \}),\par
      \{ params: Promise.resolve(\{ id: users.rep.id \}) \},\par
    );\par
    expect(res.status).toBe(409);\par
  \});\par
\par
  it("manager cannot create users", async () => \{\par
    const res = await usersPOST(\par
      makeRequest("http://localhost/api/users", \{\par
        method: "POST",\par
        userId: users.manager.id,\par
        body: \{ name: "Bad", email: "bad@ironsight.local", password: "pass", role: UserRole.REP \},\par
      \}),\par
    );\par
    expect(res.status).toBe(403);\par
  \});\par
\par
  it("rep cannot access user APIs", async () => \{\par
    const res = await usersGET(makeRequest("http://localhost/api/users", \{ userId: users.rep.id \}));\par
    expect(res.status).toBe(403);\par
  \});\par
\par
  it("users API requires session", async () => \{\par
    const res = await usersGET(makeRequest("http://localhost/api/users"));\par
    expect(res.status).toBe(401);\par
  \});\par
\});\par

\par\par
}
    const criticalStale = (await createAssignedDealForUser(\{ ownerId: users.rep.id, adminId: users.admin.id, label: "CriticalStale" \})).id;\par
    const attentionA = (await createAssignedDealForUser(\{ ownerId: users.rep.id, adminId: users.admin.id, label: "AttentionA" \})).id;\par
    const attentionB = (await createAssignedDealForUser(\{ ownerId: users.rep.id, adminId: users.admin.id, label: "AttentionB" \})).id;\par
    const upcomingToday = (await createAssignedDealForUser(\{ ownerId: users.rep.id, adminId: users.admin.id, label: "UpcomingToday" \})).id;\par
    const upcomingTwoDays = (await createAssignedDealForUser(\{ ownerId: users.rep.id, adminId: users.admin.id, label: "UpcomingTwoDays" \})).id;\par
    const noNextStep = (await createAssignedDealForUser(\{ ownerId: users.rep.id, adminId: users.admin.id, label: "NoNextStep" \})).id;\par

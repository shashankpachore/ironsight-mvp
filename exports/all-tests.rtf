\}\par
\par
/** Anchor `now` used with `getActivityComplianceRows(\{ now \})` in logic tests. */\par
const COMPLIANCE_NOW = new Date("2026-06-10T12:00:00.000Z");\par
\par
/** `n` full UTC days before `anchor` (24h steps; fine for window placement in tests). */\par
function daysAgo(anchor: Date, n: number): Date \{\par
  return new Date(anchor.getTime() - n * 86_400_000);\par
\}\par
\par
/** A timestamp on the IST “yesterday” window for `now`, at `hour` (0–23) IST-relative via window bounds. */\par
function yesterdayAt(now: Date, hour: number): Date \{\par
  const w = getComplianceWindows(now);\par
  return new Date(w.yesterdayStartUtc.getTime() + hour * 60 * 60 * 1000);\par
\}\par
\par

    expect(res.status).toBe(200);\par
    expect(body.status).toBe(AccountStatus.REJECTED);\par
  \});\par
\par
  it("duplicate normalized name is rejected", async () => \{\par
    const a = uniqueName("Globex");\par
    await createAccount(\{ byUserId: users.rep.id, name: `  $\{a\}   Health  ` \});\par
    const res = await createAccount(\{ byUserId: users.rep2.id, name: `$\{a\} health` \});\par
    expect(res.status).toBe(409);\par
  \});\par
\par
  it("similar non-normalized names are allowed", async () => \{\par
    const base = uniqueName("Northwind");\par

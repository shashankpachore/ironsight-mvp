\par
  it("rep includeAll=1 is forbidden", async () => \{\par
    await createAccount(\{ byUserId: users.rep.id, name: uniqueName("RepIncludeAllDenied") \});\par
    const res = await getAccountsRoute(makeRequest("http://localhost/api/accounts?includeAll=1", \{ userId: users.rep.id \}));\par
    expect(res.status).toBe(403);\par
  \});\par
\par
  it("pending accounts visible only to admin", async () => \{\par
    await createAccount(\{ byUserId: users.rep.id, name: uniqueName("PendingOnlyAdmin") \});\par
    const adminRes = await getPendingRoute(makeRequest("http://localhost/api/accounts/pending", \{ userId: users.admin.id \}));\par

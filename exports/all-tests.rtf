function dayOffset(days: number): Date \{\par
  const todayYmd = formatYmdInIST(new Date());\par
  return istYmdToUtcStart(addDaysYmd(todayYmd, days));\par
\}\par
\par
async function createAssignedDealForUser(params: \{\par

    expect(repRow?.weeklyActiveDays).toBe(1);\par
  \});\par
\par
  it("lastActivityAt is the latest log timestamp for the rep", async () => \{\par
    const older = daysAgo(COMPLIANCE_NOW, 5);\par
    const newer = yesterdayAt(COMPLIANCE_NOW, 18);\par
    await createLog(repDealId, older);\par
    await createLog(repDealId, newer);\par
\par
    const rows = await getActivityComplianceRows(\{\par
      viewer: \{ id: users.admin.id, role: UserRole.ADMIN \},\par
      now: COMPLIANCE_NOW,\par
    \});\par
    const repRow = rows.find((r) => r.userId === users.rep.id);\par
    expect(repRow?.lastActivityAt?.getTime()).toBe(newer.getTime());\par
  \});\par
\par
  it("manager logic view includes manager row and excludes unrelated team", async () => \{\par
    const rows = await getActivityComplianceRows(\{\par
      viewer: \{ id: users.manager.id, role: UserRole.MANAGER \},\par

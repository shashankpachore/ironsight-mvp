    repDealId = (await json<\{ id: string \}>(dealRes)).id;\par
  \});\par
\par
  async function createLog(dealId: string, createdAt: Date) \{\par
    await prisma.interactionLog.create(\{\par
      data: \{\par
        dealId,\par
        interactionType: InteractionType.CALL,\par
        outcome: Outcome.FOLLOW_UP_DONE,\par
        stakeholderType: StakeholderType.UNKNOWN,\par
        notes: "t",\par
        createdAt,\par
        risks: \{ create: [\{ category: RiskCategory.NO_ACCESS_TO_DM \}] \},\par
      \},\par
    \});\par
  \}\par
\par
  it("yesterdayCount = 0 when there are no logs", async () => \{\par
    const rows = await getActivityComplianceRows(\{\par
      viewer: \{ id: users.admin.id, role: UserRole.ADMIN \},\par
      now: COMPLIANCE_NOW,\par
    \});\par
    const repRow = rows.find((r) => r.userId === users.rep.id);\par
    expect(repRow?.yesterdayCount).toBe(0);\par
    expect(repRow?.weeklyActiveDays).toBe(0);\par
    expect(repRow?.lastActivityAt).toBeNull();\par
  \});\par
\par
  it("counts multiple logs on yesterday IST window", async () => \{\par
    const t0 = yesterdayAt(COMPLIANCE_NOW, 2);\par
    const t1 = yesterdayAt(COMPLIANCE_NOW, 8);\par
    const t2 = yesterdayAt(COMPLIANCE_NOW, 20);\par
    await createLog(repDealId, t0);\par
    await createLog(repDealId, t1);\par
    await createLog(repDealId, t2);\par
\par
    const rows = await getActivityComplianceRows(\{\par
      viewer: \{ id: users.admin.id, role: UserRole.ADMIN \},\par
      now: COMPLIANCE_NOW,\par
    \});\par
    const repRow = rows.find((r) => r.userId === users.rep.id);\par
    expect(repRow?.yesterdayCount).toBe(3);\par
  \});\par
\par
  it("weeklyActiveDays uses distinct IST dates, not raw log count", async () => \{\par
    const y1 = yesterdayAt(COMPLIANCE_NOW, 4);\par
    const y2 = yesterdayAt(COMPLIANCE_NOW, 10);\par
    const y3 = yesterdayAt(COMPLIANCE_NOW, 22);\par
    await createLog(repDealId, y1);\par
    await createLog(repDealId, y2);\par
    await createLog(repDealId, y3);\par
\par
    const rows = await getActivityComplianceRows(\{\par
      viewer: \{ id: users.admin.id, role: UserRole.ADMIN \},\par
      now: COMPLIANCE_NOW,\par
    \});\par

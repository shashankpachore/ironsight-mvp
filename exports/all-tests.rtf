];\par
\par
function primeLogs(outcomes: Outcome[], daysAgo = 0) \{\par
  const createdAt = new Date(Date.now() - daysAgo * 24 * 60 * 60 * 1000);\par
  prismaMock.interactionLog.findMany.mockResolvedValue(\par
    outcomes.map((outcome) => (\{ outcome, createdAt \})),\par
  );\par
\}\par
\par
function primeDeal(daysAgo = 0) \{\par
  const lastActivityAt = new Date(Date.now() - daysAgo * 24 * 60 * 60 * 1000);\par
  prismaMock.deal.findUnique.mockResolvedValue(\{ lastActivityAt \});\par
\}\par
\par
describe("adversarial stage + missing signal matrix (10 scenarios)", () => \{\par
  beforeEach(() => \{\par
    vi.clearAllMocks();\par
  \});\par
\par
  it.each(scenarios)("scenario: $key", async (scenario) => \{\par
    primeLogs(scenario.outcomes, scenario.logsDaysAgo ?? 0);\par
    primeDeal(scenario.lastActivityAtDaysAgo ?? 0);\par
\par
    const stage = await getDealStage(`deal-$\{scenario.key\}`);\par
    const missingSignals = await getMissingSignals(`deal-$\{scenario.key\}`);\par
\par
    expect(stage).toBe(scenario.expectedStage);\par
    for (const expectedSignal of scenario.expectedMissingSignals ?? []) \{\par
      expect(missingSignals).toContain(expectedSignal);\par
    \}\par
  \});\par
\});\par
\par
describe("critical adversarial checks", () => \{\par
  beforeEach(() => \{\par
    vi.clearAllMocks();\par
  \});\par
\par
  it("A. FALSE PROGRESS: decision maker only should NOT jump to EVALUATION", async () => \{\par
    primeLogs([Outcome.MET_DECISION_MAKER]);\par
    const stage = await getDealStage("false-progress");\par
    expect(stage).not.toBe("EVALUATION");\par
    expect(stage).toBe("ACCESS");\par
  \});\par
\par
  it("B. NO MOVEMENT SPAM: repeated NO_RESPONSE should not increase stage and should flag missing", async () => \{\par
    primeLogs([\par
      Outcome.NO_RESPONSE,\par
      Outcome.NO_RESPONSE,\par
      Outcome.NO_RESPONSE,\par
      Outcome.NO_RESPONSE,\par
    ]);\par
    primeDeal(1);\par
\par
    const [stage, missingSignals] = await Promise.all([\par
      getDealStage("no-movement-spam"),\par
      getMissingSignals("no-movement-spam"),\par
    ]);\par
\par
    expect(stage).toBe("ACCESS");\par
    expect(missingSignals).toContain("Missing Decision Maker");\par
    expect(missingSignals).toContain("Missing Budget Discussion");\par
  \});\par

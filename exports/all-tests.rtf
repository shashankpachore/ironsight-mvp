    const reject = await rejectPOST(makeRequest("http://localhost/api/accounts/reject", \{ method: "POST", body: \{\} \}), \{ params: Promise.resolve(\{ id: created.id \}) \});\par
    expect(approve.status).toBe(401);\par
    expect(reject.status).toBe(401);\par
  \});\par
\par
  it("users POST is admin-only", async () => \{\par
    const seeded = await resetDbAndSeedUsers();\par
    const bad = await usersPOST(\par
      makeRequest("http://localhost/api/users", \{\par
        method: "POST",\par
        userId: seeded.manager.id,\par
        body: \{ name: "x", email: "x@ironsight.local", password: "x", role: UserRole.REP \},\par
      \}),\par
    );\par
    const ok = await usersPOST(\par
      makeRequest("http://localhost/api/users", \{\par
        method: "POST",\par
        userId: seeded.admin.id,\par
        body: \{\par
          name: "ok",\par

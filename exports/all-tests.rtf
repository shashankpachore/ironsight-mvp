import \{ beforeEach, describe, expect, it \} from "vitest";\par
import \{ GET as dealsGET \} from "../app/api/deals/route";\par
import \{ POST as logsPOST \} from "../app/api/logs/route";\par
import \{ InteractionType, Outcome, RiskCategory, StakeholderType \} from "@prisma/client";\par
import \{ defaultNextStepRequestFields \} from "../lib/next-step";\par
import \{ approveAccount, assignAccount, createAccount, createDeal, json, makeRequest, resetDbAndSeedUsers, uniqueName \} from "./helpers";\par
import \{ PRODUCT_OPTIONS \} from "../lib/products";\par
import \{ prisma \} from "../lib/prisma";\par
\par
describe("account reassignment effects", () => \{\par
  let users: Awaited<ReturnType<typeof resetDbAndSeedUsers>>;\par
  let accountId: string;\par
  let dealId: string;\par
\par
  beforeEach(async () => \{\par
    users = await resetDbAndSeedUsers();\par
    const acc = await json<\{ id: string \}>(await createAccount(\{ byUserId: users.admin.id, name: uniqueName("AccRe") \}));\par
    accountId = acc.id;\par
    await approveAccount(\{ byUserId: users.admin.id, accountId \});\par
    await assignAccount(\{ byUserId: users.admin.id, accountId, assigneeId: users.rep.id \});\par
    dealId = (await json<\{ id: string \}>(await createDeal(\{ byUserId: users.rep.id, accountId, value: 100, name: PRODUCT_OPTIONS[0] \}))).id;\par
  \});\par
\par
  it("REP A loses deal access immediately after reassignment", async () => \{\par
    await assignAccount(\{ byUserId: users.admin.id, accountId, assigneeId: users.rep2.id \});\par
    const res = await dealsGET(makeRequest("http://localhost/api/deals", \{ userId: users.rep.id \}));\par
    const rows = (await res.json()) as Array<\{ id: string \}>;\par
    expect(rows.some((d) => d.id === dealId)).toBe(false);\par
  \});\par
\par
  it("REP B gains deal access immediately after reassignment", async () => \{\par
    await assignAccount(\{ byUserId: users.admin.id, accountId, assigneeId: users.rep2.id \});\par
    const res = await dealsGET(makeRequest("http://localhost/api/deals", \{ userId: users.rep2.id \}));\par
    const rows = (await res.json()) as Array<\{ id: string \}>;\par
    expect(rows.some((d) => d.id === dealId)).toBe(true);\par
  \});\par
\par
  it("existing deals remain valid after reassignment", async () => \{\par
    await assignAccount(\{ byUserId: users.admin.id, accountId, assigneeId: users.rep2.id \});\par
    const deal = await prisma.deal.findUnique(\{ where: \{ id: dealId \} \});\par
    expect(deal?.accountId).toBe(accountId);\par
  \});\par
\par
  it("unassigned account blocks logging writes", async () => \{\par
    await prisma.account.update(\{ where: \{ id: accountId \}, data: \{ assignedToId: null \} \});\par
    const res = await logsPOST(\par
      makeRequest("http://localhost/api/logs", \{\par
        method: "POST",\par
        userId: users.rep.id,\par
        body: \{\par
          dealId,\par
          interactionType: InteractionType.CALL,\par
          outcome: Outcome.NO_RESPONSE,\par
          stakeholderType: StakeholderType.UNKNOWN,\par
          risks: [RiskCategory.NO_ACCESS_TO_DM],\par
          ...defaultNextStepRequestFields(Outcome.NO_RESPONSE),\par
        \},\par
      \}),\par
    );\par
    expect(res.status).toBe(400);\par
  \});\par
\});\par


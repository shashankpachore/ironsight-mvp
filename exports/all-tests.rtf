    const repRes = await getPendingRoute(makeRequest("http://localhost/api/accounts/pending", \{ userId: users.rep.id \}));\par
    expect(adminRes.status).toBe(200);\par
    expect(managerRes.status).toBe(403);\par
    expect(repRes.status).toBe(403);\par
  \});\par

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  password          String
  role              UserRole
  managerId         String?
  assignedAccounts  Account[]  @relation("AssignedAccounts")
  createdAccounts   Account[]  @relation("CreatedAccounts")
  requestedAccounts Account[]  @relation("AccountRequestedBy")
  auditLogsChanged  AuditLog[] @relation("ChangedByUser")
  deals             Deal[]
  coOwnedDeals      Deal[]     @relation("DealCoOwner")
  terminalOwnedDeals Deal[]    @relation("TerminalDealOwner")
  interactionLogParticipants InteractionLogParticipant[]
  pipelineSnapshots PipelineSnapshot[]
  manager           User?      @relation("ManagerReports", fields: [managerId], references: [id])
  reports           User[]     @relation("ManagerReports")

  @@index([managerId, role])
}

model Account {
  id            String        @id @default(cuid())
  name          String
  normalized    String        @unique
  type          AccountType   @default(SCHOOL)
  state         String        @default("UNKNOWN")
  district      String        @default("UNKNOWN")
  createdById   String
  assignedToId  String?
  status        AccountStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  requestedById String?
  assignedTo    User?         @relation("AssignedAccounts", fields: [assignedToId], references: [id])
  createdBy     User          @relation("CreatedAccounts", fields: [createdById], references: [id])
  requestedBy   User?         @relation("AccountRequestedBy", fields: [requestedById], references: [id])
  deals         Deal[]

  @@index([assignedToId, createdAt])
}

model Deal {
  id             String           @id @default(cuid())
  name           String
  companyName    String
  value          Float
  accountId      String
  ownerId        String
  coOwnerId      String?
  status         DealStatus       @default(ACTIVE)
  terminalOwnerId String?
  terminalStage   DealTerminalStage?
  createdAt      DateTime         @default(now())
  lastActivityAt DateTime         @default(now())
  nextStepDate   DateTime?
  nextStepSource String?
  nextStepType   String?
  account        Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner          User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  coOwner        User?            @relation("DealCoOwner", fields: [coOwnerId], references: [id], onDelete: SetNull)
  terminalOwner  User?            @relation("TerminalDealOwner", fields: [terminalOwnerId], references: [id], onDelete: SetNull)
  logs           InteractionLog[]

  @@index([status, createdAt])
  @@index([status, lastActivityAt])
  @@index([ownerId])
  @@index([coOwnerId])
}

model InteractionLog {
  id              String            @id @default(cuid())
  dealId          String
  interactionType InteractionType
  outcome         Outcome
  stakeholderType StakeholderType
  notes           String?
  createdAt       DateTime          @default(now())
  deal            Deal              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  risks           InteractionRisk[]
  participants    InteractionLogParticipant[]

  @@index([dealId, createdAt])
}

model InteractionLogParticipant {
  logId  String
  userId String

  log  InteractionLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([logId, userId])
  @@index([userId, logId])
}

model InteractionRisk {
  id       String         @id @default(cuid())
  logId    String
  category RiskCategory
  log      InteractionLog @relation(fields: [logId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String          @id @default(cuid())
  entityType  AuditEntityType
  entityId    String
  action      AuditAction
  changedById String
  before      Json?
  after       Json?
  createdAt   DateTime        @default(now())
  changedBy   User            @relation("ChangedByUser", fields: [changedById], references: [id], onDelete: Cascade)
}

model PipelineSnapshot {
  id         String   @id @default(cuid())
  month      String
  ownerId    String
  stage      String
  totalValue Float
  dealCount  Int
  createdAt  DateTime @default(now())
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([month, ownerId])
  @@unique([month, ownerId, stage])
}

enum UserRole {
  ADMIN
  REP
  MANAGER
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountType {
  SCHOOL
  PARTNER
}

enum DealStatus {
  ACTIVE
  EXPIRED
}

enum AuditEntityType {
  USER
  ACCOUNT
  DEAL
  LOG
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum InteractionType {
  CALL
  ONLINE_MEETING
  OFFLINE_MEETING
}

enum StakeholderType {
  INFLUENCER
  DECISION_MAKER
  UNKNOWN
}

enum Outcome {
  MET_INFLUENCER
  MET_DECISION_MAKER
  BUDGET_DISCUSSED
  DEMO_DONE
  PRICING_REQUESTED
  PROPOSAL_SHARED
  BUDGET_CONFIRMED
  NEGOTIATION_STARTED
  DEAL_CONFIRMED
  PO_RECEIVED
  NO_RESPONSE
  FOLLOW_UP_DONE
  INTERNAL_DISCUSSION
  DECISION_DELAYED
  DECISION_MAKER_UNAVAILABLE
  BUDGET_NOT_AVAILABLE
  DEAL_ON_HOLD
  LOST_TO_COMPETITOR
  DEAL_DROPPED
}

enum DealTerminalStage {
  CLOSED
  LOST
}

enum RiskCategory {
  NO_ACCESS_TO_DM
  STUCK_WITH_INFLUENCER
  BUDGET_NOT_DISCUSSED
  BUDGET_NOT_CONFIRMED
  BUDGET_INSUFFICIENT
  COMPETITOR_INVOLVED
  COMPETITOR_PREFERRED
  DECISION_DELAYED
  LOW_PRODUCT_FIT
  FEATURE_GAP
  CHAMPION_NOT_STRONG
  INTERNAL_ALIGNMENT_MISSING
}
